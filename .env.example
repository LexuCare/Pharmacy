# ─────────────────────────────────────────────────────────────
# Pharma Demo – environment configuration
# Copy this file to ".env" and fill in ONE provider's key.
# ─────────────────────────────────────────────────────────────

# Which AI provider to use: "openai" or "anthropic"
AI_PROVIDER=openai

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Server port
PORT=3000
